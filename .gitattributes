# Default behavior: normalize line endings to LF on checkout and commit
* text=auto eol=lf

# Explicitly declare text files
*.py text diff=python
*.html text diff=html
*.css text diff=css
*.js text
*.ts text
*.jsx text
*.tsx text
*.json text
*.md text
*.txt text
*.xml text
*.yml text
*.yaml text
*.csv text
*.ini text
*.cfg text
*.env.example text
.gitignore text
.gitattributes text

# Denote shell scripts and ensure LF line endings
*.sh text eol=lf
*.bash text eol=lf

# Windows specific scripts (CRLF)
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Declare files that are truly binary and should not be modified
# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.svg binary
*.tif binary
*.tiff binary
*.bmp binary

# Documents
*.pdf binary
*.docx binary
*.doc binary
*.xlsx binary
*.xls binary
*.pptx binary
*.ppt binary

# Databases
*.sqlite3 binary
*.db binary
db.sqlite3 binary
*.sqlite binary

# Fonts
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.eot binary

# Archives
*.zip binary
*.tar binary
*.gz binary
*.bz2 binary
*.7z binary
*.rar binary

# Audio / Video
*.mp3 binary
*.mp4 binary
*.avi binary
*.mov binary
*.webm binary
