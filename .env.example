SENTRY_DSN=
ENVIRONMENT=development
# Production only: set to True to force HTTPS redirects (leave False locally).
SECURE_SSL_REDIRECT=False
DJANGO_SECRET_KEY=django-insecure-example-key-do-not-use-in-production
ADMIN_EMAIL=admin@example.com
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=user
EMAIL_HOST_PASSWORD=password

# Required in production when behind an HTTPS reverse proxy (ENG-03).
# Must include scheme. Supports comma separation for multiple origins.
# Example: https://example.com,https://staging.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=
